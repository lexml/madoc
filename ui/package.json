{
    "name": "madoc-app",
    "version": "0.0.0",
    "scripts": {
        "start": "concurrently \"npm:dev-*\"  \"npm:app\" -k",
        "lint": "ng lint",
        "app": "ng serve --proxy-config proxy.conf.json",
        "watch": "concurrently \"npm:dev-*\" -k",
        "dev-madoc-lib": "ng build madoc-ui --watch",
        "dev-madoc-extras": "ng build madoc-extras --watch",
        "build-madoc-lib": "ng build --prod madoc-ui",
        "build-madoc-extras": "ng build --prod madoc-extras",
        "test-madoc-lib": "ng test madoc-ui --watch=false --code-coverage",
        "pack-madoc-lib": "cd dist/madoc-ui && npm pack",
        "pack-madoc-extras": "cd dist/madoc-extras && npm pack",
        "package-madoc-lib": "npm run build-madoc-lib && npm run test-madoc-lib && npm run pack-madoc-lib",
        "package-madoc-extras": "npm run build-madoc-extras && npm run pack-madoc-extras",
        "publish-madoc-lib": "npm publish ./dist/madoc-ui/madoc-ui*.tgz",
        "publish-madoc-extras": "npm publish ./dist/madoc-extras/madoc-extras*.tgz"
    },
    "private": true,
    "dependencies": {
        "@angular/animations": "^8.2.14",
        "@angular/common": "^8.2.14",
        "@angular/compiler": "^8.2.14",
        "@angular/core": "^8.2.14",
        "@angular/forms": "^8.2.14",
        "@angular/platform-browser": "^8.2.14",
        "@angular/platform-browser-dynamic": "^8.2.14",
        "@angular/router": "^8.2.14",
        "@types/ckeditor": "4.9.8",
        "bootstrap": "3.3.7",
        "bootstrap-datepicker": "1.9.0",
        "ckeditor": "4.12.1",
        "core-js": "3.4.7",
        "json": "^9.0.6",
        "karma-jasmine-diff-reporter": "^2.0.0",
        "karma-mocha-reporter": "^2.2.5",
        "lodash-es": "^4.17.15",
        "moment": "2.24.0",
        "ng2-ckeditor": "1.2.6",
        "ngx-bootstrap": "5.2.0",
        "ngx-extended-pdf-viewer": "^4.1.0",
        "rxjs": "6.5.3",
        "streams": "^0.1.0",
        "tsickle": "^0.37.0",
        "tslib": "^1.10.0",
        "xpath": "0.0.27",
        "xslt": "0.9.1",
        "zone.js": "~0.9.1"
    },
    "devDependencies": {
        "concurrently": "^5.0.0",
        "@angular-devkit/build-angular": "~0.803.20",
        "@angular-devkit/build-ng-packagr": "~0.803.20",
        "@angular/cli": "^8.3.20",
        "@angular/compiler-cli": "^8.2.14",
        "@angular/language-service": "^8.2.14",
        "@types/jasmine": "~3.5.0",
        "@types/jasminewd2": "~2.0.8",
        "@types/node": "~12.12.14",
        "codelyzer": "^5.0.1",
        "intl": "^1.2.5",
        "jasmine-core": "~3.5.0",
        "jasmine-spec-reporter": "~4.2.1",
        "karma": "~4.4.1",
        "karma-chrome-launcher": "~3.1.0",
        "karma-coverage-istanbul-reporter": "^2.1.1",
        "karma-jasmine": "~2.0.1",
        "karma-jasmine-html-reporter": "^1.4.2",
        "karma-phantomjs-launcher": "^1.0.4",
        "ng-packagr": "^5.4.0",
        "protractor": "~5.4.1",
        "ts-node": "~8.5.4",
        "tsickle": "^0.37.0",
        "tslib": "^1.10.0",
        "tslint": "~5.20.1",
        "typescript": "^3.4.5"
    }
}
